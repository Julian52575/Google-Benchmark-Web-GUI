## See the README.md for instructions on how to set up the environment variables.
# The GitHub repository URL, used for links to the commits
GITHUB_REPO="https://github.com/me/myrepository"
# The port to expose the backend on
BACKEND_PORT=5502
# The port to expose the frontend on
FRONTEND_PORT=5501
# The directory to the benchmark results
BENCHMARK_DIR=/var/benchmarksResults/myrepository/